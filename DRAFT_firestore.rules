rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.keys().size() <= 6 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['student', 'admin'] &&
             (data.get('savingsBalance', 0) is number);
    }

    function isValidCourse(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.keys().hasAll(['title', 'description']);
    }

    function isValidEnrollment(data) {
      return data.userId is string && data.courseId is string &&
             data.progress is number && data.progress >= 0 && data.progress <= 100 &&
             data.keys().hasAll(['userId', 'courseId', 'progress']);
    }

    function isValidCertificate(data) {
      return data.userId is string && data.courseId is string &&
             data.issueDate is timestamp &&
             data.keys().hasAll(['userId', 'courseId', 'issueDate']);
    }

    function isValidTransaction(data) {
      return data.userId is string && data.amount is number &&
             data.type in ['deposit', 'withdrawal', 'loan_repayment'] &&
             data.timestamp is timestamp &&
             data.keys().hasAll(['userId', 'amount', 'type', 'timestamp']);
    }

    function isValidLoanRequest(data) {
      return data.userId is string && data.amount is number &&
             data.purpose is string && data.purpose.size() <= 500 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is timestamp &&
             data.keys().hasAll(['userId', 'amount', 'purpose', 'status', 'createdAt']);
    }

    // Rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'student';
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        // Action: Update Profile
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email'])) ||
        // Action: Update Balance (System/Admin only in a real app, but for this demo let's allow restricted update)
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['savingsBalance', 'role']))
      );
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /enrollments/{enrollmentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidEnrollment(incoming());
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin()) && isValidEnrollment(incoming()) && (
         incoming().diff(existing()).affectedKeys().hasOnly(['progress', 'completed', 'dateCompleted'])
      );
    }

    match /certificates/{certificateId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin(); // Only system/admin issues certificates
    }

    match /savings/{transactionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidTransaction(incoming());
    }

    match /loanRequests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidLoanRequest(incoming()) && 
                    incoming().status == 'pending';
      allow update: if isAdmin() && isValidLoanRequest(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }
  }
}
